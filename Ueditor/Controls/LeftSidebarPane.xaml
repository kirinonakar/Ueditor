<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Ueditor.Controls.LeftSidebarPane"
    x:Name="RootLeftSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Ueditor.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:LocalizationBridge x:Key="LocBridge"/>
        <Style x:Key="FlatActivityButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                            <!-- Left active indicator bar -->
                             <Rectangle x:Name="ActiveIndicator" 
                                       Width="3" 
                                       HorizontalAlignment="Left" 
                                       Fill="{ThemeResource AccentTextFillColorPrimaryBrush}" 
                                       Visibility="Collapsed"
                                       VerticalAlignment="Stretch"
                                       Margin="0,6,0,6"/>
                            
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              AutomationProperties.AccessibilityView="Raw"/>
                            
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SystemControlBackgroundBaseMediumBrush}"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SidebarBackgroundBrush}"/>
                                            <Setter Target="ActiveIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SidebarBackgroundBrush}"/>
                                            <Setter Target="ActiveIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SystemControlBackgroundBaseMediumBrush}"/>
                                            <Setter Target="ActiveIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- A. Left Panel (File Explorer & Favorites & Recent Files & Search & Git & Snippets) -->
    <Grid x:Name="SidebarRoot" Background="{ThemeResource SidebarBackgroundBrush}" BorderBrush="{ThemeResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="38"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{ThemeResource ActivityBarBackgroundBrush}" BorderBrush="{ThemeResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Padding="0,4,0,4" Spacing="0">
                <ToggleButton x:Name="ExplorerActivityButton" Tag="0" IsChecked="True" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE8B7;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="FavoritesActivityButton" Tag="1" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE734;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="RecentActivityButton" Tag="2" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE81C;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="SearchActivityButton" Tag="3" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE721;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="TocActivityButton" Tag="6" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE169;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="GitActivityButton" Tag="4" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE139;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="SnippetsActivityButton" Tag="5" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE943;" FontSize="13"/>
                </ToggleButton>
            </StackPanel>
        </Border>
    
                    <Grid Grid.Column="1">
                        
                        <!-- Tab 1: File Explorer -->
                        <Grid x:Name="ExplorerSidebarPage">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="10" Spacing="8">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                    <Button x:Name="ExplorerUpButton" Content="↑" Click="OnExplorerUpClick" ToolTipService.ToolTip="상위 폴더" Padding="8,0" FontSize="11" Height="32"/>
                                    <Button x:Name="ExplorerSelectFolderButton" Grid.Column="1" Content="폴더 선택..." HorizontalAlignment="Stretch" Click="OnSelectFolderClick" Style="{StaticResource AccentButtonStyle}" FontSize="11" Height="32"/>
                                    <Button x:Name="ExplorerTerminalButton" Grid.Column="2" Click="OnOpenTerminalClick" ToolTipService.ToolTip="현재 폴더에서 터미널 열기" Padding="8,0" Height="32">
                                            <FontIcon Glyph="&#xE756;" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                    <TextBlock x:Name="ExplorerStatusText" Text="폴더를 선택하세요." FontSize="11" TextWrapping="Wrap" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                                <ListView x:Name="FileListView" Grid.Row="1" Margin="5" SelectionMode="Single" DoubleTapped="OnFileListViewDoubleTapped">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="4,3,4,3" RightTapped="OnFileListViewItemRightTapped">
                                                <Grid.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="즐겨찾기에 추가" Click="OnAddFileToFavoritesClick" Tag="{Binding}"/>
                                                        <MenuFlyoutItem Text="폴더를 즐겨찾기에 추가" Click="OnAddFolderToFavoritesClick" Tag="{Binding}"/>
                                                    </MenuFlyout>
                                                </Grid.ContextFlyout>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <FontIcon.Foreground>
                                                        <SolidColorBrush Color="{Binding IconColor}"/>
                                                    </FontIcon.Foreground>
                                                </FontIcon>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                        </Grid>
    
                        <!-- Tab 2: Favorites -->
                        <Grid x:Name="FavoritesSidebarPage" Padding="10" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" x:Name="FavoritesHeaderText" Text="즐겨찾기 목록" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,8"/>
                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="FavoritesFileTab" Grid.Column="0" Content="파일" FontSize="11" Height="24" Padding="8,0" IsChecked="True" Click="OnFavoritesTabClick"/>
                                    <ToggleButton x:Name="FavoritesFolderTab" Grid.Column="1" Content="폴더" FontSize="11" Height="24" Padding="8,0" Margin="4,0,0,0" Click="OnFavoritesTabClick"/>
                                    <TextBlock x:Name="FavoritesPinIndicator" Grid.Column="3" Text="📌" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" ToolTipService.ToolTip="고정된 항목은 맨 위에 표시됩니다"/>
                                </Grid>
                                <ListView x:Name="FavoritesListView" Grid.Row="2" SelectionMode="Single" DoubleTapped="OnFavoriteItemDoubleTapped">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,4,0,4" ToolTipService.ToolTip="{Binding Path}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <FontIcon.Foreground>
                                                        <SolidColorBrush Color="{Binding IconColor}"/>
                                                    </FontIcon.Foreground>
                                                </FontIcon>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Path}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" x:Name="FavoritePinButton" Content="📌" FontSize="10" Background="Transparent" BorderBrush="Transparent" Padding="3" VerticalAlignment="Center" Opacity="{Binding PinOpacity}" Click="OnFavoritePinClick" Tag="{Binding}" ToolTipService.ToolTip="고정"/>
                                                <Button Grid.Column="3" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnRemoveFavoriteClick" Tag="{Binding Path}" Padding="3" VerticalAlignment="Center" FontSize="10"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                        </Grid>
    
                        <!-- Tab 3: Recent Files -->
                        <Grid x:Name="RecentSidebarPage" Padding="10" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="RecentFilesHeaderText" Grid.Row="0" Text="최근 파일" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,10"/>
                            <ListView x:Name="RecentFilesListView" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnRecentFileItemDoubleTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,4,0,4" ToolTipService.ToolTip="{Binding Path}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Path}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnRemoveRecentFileClick" Tag="{Binding Path}" Padding="3" VerticalAlignment="Center" FontSize="10"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
    
                        <!-- Tab 4: Search & Replace Panel -->
                        <Grid x:Name="SearchSidebarPage" Padding="10" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Form Inputs -->
                                    <RowDefinition Height="*"/>    <!-- Results -->
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,10">
                                    <TextBlock x:Name="SearchHeaderText" Text="폴더 전체 검색 및 바꾸기" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBox x:Name="SearchQueryInput" PlaceholderText="검색어 입력..." KeyDown="OnSearchQueryInputKeyDown" Height="32" FontSize="12" FontFamily="Segoe UI, Malgun Gothic" VerticalContentAlignment="Center" Padding="10,8,10,0" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollMode="Disabled" IsSpellCheckEnabled="False" IsTextPredictionEnabled="False"/>
                                    <TextBox x:Name="ReplaceQueryInput" PlaceholderText="바꿀 단어 입력..." Height="32" FontSize="12" FontFamily="Segoe UI, Malgun Gothic" VerticalContentAlignment="Center" Padding="10,8,10,0" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollMode="Disabled" IsSpellCheckEnabled="False" IsTextPredictionEnabled="False"/>
                                    
                                    <Grid ColumnSpacing="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton x:Name="SearchMatchCaseToggle" Content="Aa" ToolTipService.ToolTip="대소문자 구분" HorizontalAlignment="Stretch" FontSize="11"/>
                                        <ToggleButton x:Name="SearchWholeWordToggle" Content="[ab]" Grid.Column="1" ToolTipService.ToolTip="단어 단위" HorizontalAlignment="Stretch" FontSize="11"/>
                                        <ToggleButton x:Name="SearchRegexToggle" Content=".*" Grid.Column="2" ToolTipService.ToolTip="정규식 검색" HorizontalAlignment="Stretch" FontSize="11"/>
                                    </Grid>
     
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="SearchAllButton" Content="전체 검색" HorizontalAlignment="Stretch" Click="OnSearchAllFilesClick" Style="{StaticResource AccentButtonStyle}" FontSize="11"/>
                                        <Button x:Name="ReplaceAllButton" Content="모두 바꾸기" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnReplaceAllClick" FontSize="11"/>
                                    </Grid>
                                </StackPanel>
    
                                <ListView x:Name="SearchResultsList" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnSearchResultDoubleTapped">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,5,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding HeaderText}" FontWeight="Bold" FontSize="11" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                    <TextBlock Text="{Binding LineContent}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding DisplayPath}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#xE194;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnReplaceOneClick" Tag="{Binding}" Padding="4" Margin="5,0,0,0" VerticalAlignment="Center" ToolTipService.ToolTip="{Binding Path=ReplaceOneTooltip, Source={StaticResource LocBridge}}" FontSize="11"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                        </Grid>
    
                        <!-- Tab 5: Git Panel -->
                        <Grid x:Name="GitSidebarPage" Padding="10" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Branch Info -->
                                    <RowDefinition Height="*"/>    <!-- Changed Files -->
                                    <RowDefinition Height="Auto"/> <!-- Commit controls -->
                                    <RowDefinition Height="Auto"/> <!-- History -->
                                    <RowDefinition Height="Auto"/> <!-- Bottom Actions -->
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Margin="0,0,0,10" Spacing="5">
                                    <TextBlock x:Name="GitHeaderText" Text="Git 저장소 관리" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock x:Name="GitPanelBranchText" Text="Git: 감지 안됨" FontSize="13" FontWeight="SemiBold"/>
                                    <ComboBox x:Name="GitBranchesCombo" PlaceholderText="브랜치 목록" Height="24" FontSize="10" Padding="6,0,4,0" HorizontalAlignment="Stretch"/>
                                </StackPanel>
    
                                <ListView x:Name="GitChangedFilesList" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnGitFileDoubleTapped">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Path}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="3" Padding="4,1,4,1" Margin="5,0,5,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusText}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <Button Grid.Column="2" Content="{Binding ActionGlyph}" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnGitStageToggleClick" Tag="{Binding Path}" Padding="3" VerticalAlignment="Center" FontSize="10"/>
                                                <Button Grid.Column="3" Content="&#xE777;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnGitRestoreFileClick" Tag="{Binding Path}" Padding="3" VerticalAlignment="Center" ToolTipService.ToolTip="파일 복원" FontSize="10"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
    
                                <StackPanel Grid.Row="2" Spacing="8" Margin="0,10,0,0">
                                    <TextBox x:Name="GitCommitMessageInput" PlaceholderText="커밋 메시지 입력..." Height="32" FontSize="12" FontFamily="Segoe UI, Malgun Gothic" VerticalContentAlignment="Center" Padding="10,8,10,0" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollMode="Disabled" IsSpellCheckEnabled="False" IsTextPredictionEnabled="False"/>
                                    <Button x:Name="GitCommitButton" Content="커밋 (Commit)" HorizontalAlignment="Stretch" Click="OnGitCommitClick" Style="{StaticResource AccentButtonStyle}" FontSize="11"/>
                                </StackPanel>
    
                                <StackPanel Grid.Row="3" Spacing="8" Margin="0,8,0,0">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="GitStageAllButton" Content="전체 Stage" HorizontalAlignment="Stretch" Click="OnGitStageAllClick" FontSize="11"/>
                                    <Button x:Name="GitRestoreAllButton" Grid.Column="1" Content="전체 Restore" HorizontalAlignment="Stretch" Click="OnGitRestoreAllClick" FontSize="11"/>
                                    </Grid>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="GitPushButton" Content="Push" HorizontalAlignment="Stretch" Click="OnGitPushClick" FontSize="11"/>
                                    <Button x:Name="GitRefreshButton" Grid.Column="1" Content="새로고침" HorizontalAlignment="Stretch" Click="OnGitRefreshClick" FontSize="11"/>
                                    </Grid>
                                </StackPanel>
    
                                <StackPanel Grid.Row="4" Spacing="4" Margin="0,8,0,0">
                                    <TextBlock x:Name="GitHistoryHeader" Text="과거 기록" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <ListView x:Name="GitHistoryList" Height="120" SelectionMode="Single" DoubleTapped="OnGitHistoryItemDoubleTapped">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="0,2,0,2">
                                                    <TextBlock Text="{Binding}" FontSize="10" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                        </Grid>
    
                        <!-- Tab 6: Snippets Hub -->
                        <Grid x:Name="SnippetsSidebarPage" Padding="10" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="SnippetsHeaderText" Grid.Row="0" Text="코드 및 수식 템플릿" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,10"/>
                                <ListView x:Name="SnippetsListView" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnSnippetItemDoubleTapped">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Keyword}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                    <Button Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnEditSnippetClick" Padding="3" FontSize="10" ToolTipService.ToolTip="{Binding Path=SnippetEditTooltip, Source={StaticResource LocBridge}}"/>
                                                    <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnDeleteSnippetClick" Tag="{Binding Title}" Padding="3" FontSize="10" ToolTipService.ToolTip="{Binding Path=SnippetDeleteTooltip, Source={StaticResource LocBridge}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <StackPanel Grid.Row="2" Margin="0,10,0,0" Spacing="8">
                                    <Button x:Name="AddSnippetButton" Content="스니펫 추가..." HorizontalAlignment="Stretch" Click="OnAddSnippetClick" Style="{StaticResource AccentButtonStyle}"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="ExportSnippetsButton" Grid.Column="0" Content="내보내기" Click="OnExportSnippetsClick" HorizontalAlignment="Stretch" FontSize="11"/>
                                        <Button x:Name="ImportSnippetsButton" Grid.Column="1" Content="가져오기" Click="OnImportSnippetsClick" HorizontalAlignment="Stretch" FontSize="11"/>
                                    </Grid>
                                    <Button x:Name="ResetSnippetsButton" Content="초기화" Click="OnResetSnippetsClick" HorizontalAlignment="Stretch" FontSize="11"/>
                                </StackPanel>
                        </Grid>

                        <!-- Tab 7: TOC (Table of Contents) Outline -->
                        <Grid x:Name="TocSidebarPage" Padding="10" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TocHeaderText" Grid.Row="0" Text="목차 (TOC)" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,10"/>
                            <ListView x:Name="TocListView" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnTocItemDoubleTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,4,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayText}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="{Binding Margin}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding LineDisplay}" FontSize="10" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Grid>
</UserControl>
