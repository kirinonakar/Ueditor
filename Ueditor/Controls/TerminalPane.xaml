<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Ueditor.Controls.TerminalPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="TerminalRootBackground" Color="#F3F4F6"/>
                    <SolidColorBrush x:Key="TerminalHeaderBackground" Color="#E5E7EB"/>
                    <SolidColorBrush x:Key="TerminalBorder" Color="#D1D5DB"/>
                    <SolidColorBrush x:Key="TerminalSidebarBackground" Color="#F9FAFB"/>
                    <SolidColorBrush x:Key="TerminalTextBoxBackground" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="TerminalTextBoxForeground" Color="#1F2937"/>

                    <!-- Custom ScrollBar Styling for Light Mode -->
                    <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarBrowserBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarTrackBackgroundPointerOver" Color="#F3F4F6"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBackground" Color="#C1C1C1"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBackgroundPointerOver" Color="#A6A6A6"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBackgroundPressed" Color="#8C8C8C"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBorderBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBorderBrushPressed" Color="Transparent"/>
                    
                    <SolidColorBrush x:Key="ScrollBarButtonBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBackgroundPressed" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonForeground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonForegroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonForegroundPressed" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBorderBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBorderBrushPressed" Color="Transparent"/>
                    
                    <!-- Custom ScrollBar Size overrides (sleek and thin) -->
                    <x:Double x:Key="ScrollBarSize">8</x:Double>
                    <x:Double x:Key="ScrollBarThumbThickness">6</x:Double>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="TerminalRootBackground" Color="#18191B"/>
                    <SolidColorBrush x:Key="TerminalHeaderBackground" Color="#1E1F22"/>
                    <SolidColorBrush x:Key="TerminalBorder" Color="#2E3033"/>
                    <SolidColorBrush x:Key="TerminalSidebarBackground" Color="#151618"/>
                    <SolidColorBrush x:Key="TerminalTextBoxBackground" Color="#1E1E1E"/>
                    <SolidColorBrush x:Key="TerminalTextBoxForeground" Color="#D4D4D4"/>

                    <!-- Custom ScrollBar Styling for Dark Mode -->
                    <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarBrowserBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarTrackBackgroundPointerOver" Color="#252629"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBackground" Color="#4E4E4E"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBackgroundPointerOver" Color="#606060"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBackgroundPressed" Color="#7A7A7A"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBorderBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarThumbBorderBrushPressed" Color="Transparent"/>
                    
                    <SolidColorBrush x:Key="ScrollBarButtonBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBackgroundPressed" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonForeground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonForegroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonForegroundPressed" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBorderBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ScrollBarButtonBorderBrushPressed" Color="Transparent"/>
                    
                    <!-- Custom ScrollBar Size overrides (sleek and thin) -->
                    <x:Double x:Key="ScrollBarSize">8</x:Double>
                    <x:Double x:Key="ScrollBarThumbThickness">6</x:Double>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="TerminalRootGrid"
          BorderBrush="{ThemeResource TerminalBorder}"
          BorderThickness="0,1,0,0"
          Background="{ThemeResource TerminalRootBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="TerminalHeaderGrid" 
              Grid.Row="0" 
              Grid.ColumnSpan="2" 
              Padding="12,6,12,6" 
              ColumnSpacing="8"
              Background="{ThemeResource TerminalHeaderBackground}"
              BorderBrush="{ThemeResource TerminalBorder}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TerminalTitleText"
                       Text="터미널" FontSize = "12"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TerminalTextBoxForeground}"/>
            <Button x:Name="NewTerminalButton" Grid.Column="1" Content="새 터미널" FontSize = "12" Click="OnNewTerminalClick" Padding="12,4,12,4" CornerRadius="4"/>
            <Button x:Name="CloseTerminalButton" Grid.Column="2" Content="닫기" FontSize = "12" Click="OnCloseTerminalClick" Padding="12,4,12,4" CornerRadius="4"/>
        </Grid>

        <Border x:Name="TerminalHostBorder"
                Grid.Row="1"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Black"
                Visibility="Collapsed"
                SizeChanged="OnTerminalHostBorderSizeChanged"
                PointerPressed="OnTerminalHostBorderPointerPressed"/>

        <TextBox x:Name="TerminalOutputTextBox"
                 Grid.Row="1"
                 Grid.Column="0"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="12"
                 BorderThickness="0"
                 Background="{ThemeResource TerminalTextBoxBackground}"
                 Foreground="{ThemeResource TerminalTextBoxForeground}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

        <Grid x:Name="TerminalInputAreaGrid" Grid.Row="2" Grid.Column="0" Padding="8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="PS>"
                       VerticalAlignment="Center"
                       FontFamily="Consolas"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TerminalTextBoxForeground}"/>
            <TextBox x:Name="TerminalInputBox"
                     Grid.Column="1"
                     PlaceholderText="명령 입력 후 Enter"
                     FontFamily="Consolas"
                     Foreground="{ThemeResource TerminalTextBoxForeground}"
                     Background="{ThemeResource TerminalTextBoxBackground}"
                     BorderBrush="{ThemeResource TerminalBorder}"
                     BorderThickness="1"
                     CornerRadius="4"
                     KeyDown="OnTerminalInputKeyDown"/>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="1"
                Grid.RowSpan="2"
                BorderBrush="{ThemeResource TerminalBorder}"
                BorderThickness="1,0,0,0"
                Background="{ThemeResource TerminalSidebarBackground}">
            <ListView x:Name="TerminalSessionsList"
                      SelectionMode="Single"
                      SelectionChanged="OnTerminalSessionsListSelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="6,4,6,4" ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DisplayTitle}" 
                                       TextTrimming="CharacterEllipsis" 
                                       FontSize="11" 
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TerminalTextBoxForeground}"/>
                            <Button Grid.Column="1"
                                    Content="&#xE8BB;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="8"
                                    Padding="4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{ThemeResource TerminalTextBoxForeground}"
                                    Click="OnCloseSessionItemClick"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</UserControl>
