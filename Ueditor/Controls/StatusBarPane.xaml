<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Ueditor.Controls.StatusBarPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
            Height="26"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
        <Grid Margin="6,0,6,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ToggleButton x:Name="LeftPanelToggle"
                          Grid.Column="0"
                          Width="26"
                          Height="22"
                          Padding="0"
                          IsChecked="True"
                          Click="HandleLeftPanelToggleClick"
                          ToolTipService.ToolTip="좌측 패널">
                <FontIcon Glyph="&#xE145;" FontSize="11"/>
            </ToggleButton>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center" Margin="8,0,0,0">
                <Button x:Name="LineNumberButton" Padding="0" Background="Transparent" BorderBrush="Transparent" Click="HandleLineNumberClick" ToolTipService.ToolTip="클릭하여 줄 이동">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock x:Name="StatusLineLabel" Text="줄" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusLine" Text="1" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=":" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusColumnLabel" Text="열" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusCol" Text="1" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock x:Name="StatusFileStats" Text="크기: 0 bytes" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                <Button x:Name="LineEndingButton" Padding="4,0" Background="Transparent" BorderBrush="Transparent" Click="HandleLineEndingClick" ToolTipService.ToolTip="클릭하여 줄 끝 방식 변경">
                    <TextBlock x:Name="StatusLineEnding" Text="LF" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                <TextBlock x:Name="StatusGitBranch" Text="Git: 감지 안됨" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusLanguage" Text="PLAINTEXT" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="StatusEncodingCombo"
                          Width="100"
                          Height="20"
                          FontSize="10"
                          Padding="4,0,4,0"
                          SelectionChanged="HandleEncodingSelectionChanged"
                          ToolTipService.ToolTip="파일 인코딩 선택"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <ToggleButton x:Name="RightPanelToggle"
                          Grid.Column="4"
                          Width="26"
                          Height="22"
                          Padding="0"
                          IsChecked="True"
                          Click="HandleRightPanelToggleClick"
                          ToolTipService.ToolTip="우측 패널"
                          Margin="8,0,0,0">
                <FontIcon Glyph="&#xE145;" FontSize="11" RenderTransformOrigin="0.5,0.5">
                    <FontIcon.RenderTransform>
                        <ScaleTransform ScaleX="-1"/>
                    </FontIcon.RenderTransform>
                </FontIcon>
            </ToggleButton>
        </Grid>
    </Border>
</UserControl>
