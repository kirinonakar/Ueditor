<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Ueditor.Controls.RightSidebarPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

                <Grid x:Name="RightSidebarRoot" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                    <TabView x:Name="RightTabView" 
                             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                             IsAddTabButtonVisible="False" AllowDropTabs="False">
                        
                        <!-- Tab 1: Live Preview -->
                        <TabViewItem x:Name="LivePreviewTab" Header="실시간 프리뷰" IsClosable="False">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Preview Toolbar -->
                                <Border BorderBrush="{ThemeResource ToolbarBorderBrush}" BorderThickness="0,0,0,1">
                                    <CommandBar Grid.Row="0" Background="{ThemeResource ToolbarBackgroundBrush}" Height="40" DefaultLabelPosition="Right">
                                        <CommandBar.Content>
                                            <StackPanel Orientation="Horizontal" Margin="10,8,0,0" Spacing="10">
                                                <ComboBox x:Name="PreviewModeCombo" SelectedIndex="0" Height="24" Padding="5,0,5,0" Width="120" FontSize="11" SelectionChanged="OnPreviewModeComboSelectionChanged">
                                                    <ComboBoxItem x:Name="ComboItemMarkdown" Content="Markdown"/>
                                                    <ComboBoxItem x:Name="ComboItemHtml" Content="HTML Preview"/>
                                                    <ComboBoxItem x:Name="ComboItemLatex" Content="LaTeX Block"/>
                                                    <ComboBoxItem x:Name="ComboItemAozora" Content="Aozora"/>
                                                </ComboBox>
                                                <Button x:Name="OpenBrowserButton" Click="OnOpenPreviewInBrowserClick" Height="24" Padding="8,0,8,0" ToolTipService.ToolTip="HTML 미리보기를 브라우저로 열기">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE774;" FontSize="12"/>
                                                        <TextBlock x:Name="OpenBrowserButtonText" Text="브라우저" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </CommandBar.Content>
                                    </CommandBar>
                                </Border>
    
                                <WebView2 x:Name="PreviewWebView" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            </Grid>
                        </TabViewItem>
    
                        <!-- Tab 2: AI Assistant -->
                        <TabViewItem x:Name="AiAssistantTab" Header="AI Assistant" IsClosable="False">
                            <Grid Padding="15" RowSpacing="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>    <!-- AI Chat Logs Area -->
                                    <RowDefinition Height="Auto"/> <!-- Selection Context Visualizer -->
                                    <RowDefinition Height="Auto"/> <!-- Quick Action Buttons -->
                                </Grid.RowDefinitions>
    
                                <!-- Row 0: AI Chat Output Area -->
                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" Padding="10" CornerRadius="4">
                                    <TextBlock x:Name="LlmOutputText" Text="대기 중... 에디터에서 영역을 선택한 후 하단의 AI 분석 도구를 사용해 보세요." TextWrapping="Wrap" FontSize="13" LineHeight="1.5" IsTextSelectionEnabled="True"/>
                                </ScrollViewer>
    
                                <!-- Row 1: Selected Context Info visualizer -->
                                <Border Grid.Row="1" Background="{ThemeResource ToolbarBackgroundBrush}" Padding="8" CornerRadius="4">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <FontIcon Glyph="&#xE94A;" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="SelectionStatsText" Text="선택 영역: 없음 (전체 전송 차단 활성화)" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="LlmFileContextInput" PlaceholderText="파일 맥락 없음" IsReadOnly="True" Height="30" FontSize="11"/>
                                            <Button x:Name="LlmAddFileContextButton" Grid.Column="1" Content="파일 맥락 추가" Click="OnLlmAddFileContextClick" Padding="10,4,10,4"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
    
                                <!-- Row 2: Quick Action Buttons -->
                                <StackPanel Grid.Row="2" Spacing="8">
                                    <Button x:Name="LlmExplainButton" Content="선택 영역 설명 (Explain)" HorizontalAlignment="Stretch" Click="OnLlmExplainClick" Style="{StaticResource AccentButtonStyle}"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="LlmSummarizeButton" Content="선택 영역 요약" Grid.Column="0" HorizontalAlignment="Stretch" Click="OnLlmSummarizeClick"/>
                                        <Button x:Name="LlmTranslateButton" Content="선택 영역 번역" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnLlmTranslateClick"/>
                                    </Grid>
    
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="LlmImproveButton" Content="수식/마크다운 개선" HorizontalAlignment="Stretch" Click="OnLlmImproveClick"/>
                                    </Grid>
                                    
                                    <Grid ColumnSpacing="8" Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="LlmCustomPromptInput" Grid.Column="0" PlaceholderText="질문이나 커스텀 지시사항 입력..." Height="32"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                            <Button x:Name="LlmCustomRunButton" Content="실행" Click="OnLlmCustomClick" Style="{StaticResource AccentButtonStyle}"/>
                                            <Button x:Name="LlmInsertOutputButton" Content="입력" Click="OnLlmInsertOutputClick" ToolTipService.ToolTip="AI 응답을 현재 커서에 입력"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </TabViewItem>
    
                    </TabView>
                </Grid>
</UserControl>
