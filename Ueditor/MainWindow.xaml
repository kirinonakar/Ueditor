<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Ueditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ueditor"
    xmlns:controls="using:Ueditor.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Ueditor">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent" AllowDrop="True" DragOver="OnRootDragOver" Drop="OnRootDrop" KeyDown="OnRootKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="36"/> <!-- Custom Title Bar -->
            <RowDefinition Height="Auto"/> <!-- Top Command Toolbar -->
            <RowDefinition Height="Auto"/> <!-- Markdown Toolbar -->
            <RowDefinition Height="*"/>    <!-- Main Body Work Area -->
            <RowDefinition Height="Auto"/> <!-- Bottom Status Bar -->
        </Grid.RowDefinitions>

        <!-- 0. Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="{ThemeResource TitleBarBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <Image Source="ms-appx:///Assets/Ueditor.png" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="AppTitleTextBlock" Text="Ueditor" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TitleBarForegroundBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 0b. Exit Sticky Note Bar -->
        <Grid x:Name="ExitStickyNoteBar" Grid.Row="0" Background="{ThemeResource TitleBarBackgroundBrush}" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="{ThemeResource TitleBarForegroundBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StickyNoteTitleText" Text="스티커 노트" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{ThemeResource TitleBarForegroundBrush}"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ToggleButton x:Name="StickyNoteTopMostButton" Click="OnStickyNoteTopMostClick" 
                               Height="28" Padding="12,0,12,0" CornerRadius="4" BorderThickness="0"
                               Foreground="{ThemeResource TitleBarForegroundBrush}"
                               FontSize="12" FontWeight="SemiBold">
                    <ToggleButton.Resources>
                        <SolidColorBrush x:Key="ToggleButtonBackground" Color="Transparent"/>
                        
                        <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#15808080"/>
                        
                        <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#30808080"/>

                        <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#0078D4"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="White"/>
                        
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#106EBE"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="White"/>

                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#005A9E"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="White"/>
                    </ToggleButton.Resources>
                    <ToggleButton.Content>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE718;" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StickyNoteTopMostText" Text="항상 위" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton.Content>
                </ToggleButton>

                <Button x:Name="ExitStickyNoteButton" Click="OnExitStickyNoteClick" 
                        Background="#FF5C5C" Foreground="White" BorderThickness="0" CornerRadius="4"
                        Height="28" Padding="12,0,12,0" FontSize="12" FontWeight="SemiBold">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE711;" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ExitStickyNoteText" Text="나가기" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF7373"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E04343"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 1. Top Command Toolbar (상단 툴바) -->
        <controls:TopCommandBarPane x:Name="TopToolbar" Grid.Row="1"/>

        <controls:MarkdownToolbarControl x:Name="MarkdownToolbar"
                                         Grid.Row="2"
                                         Visibility="Collapsed"/>

        <!-- 2. Main Work Area -->
        <Grid x:Name="MainWorkGrid" Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ExplorerColumn" Width="260" MinWidth="150" MaxWidth="500"/> <!-- Col 0: Left Side Explorer Panel -->
                <ColumnDefinition Width="Auto"/>                                                      <!-- Col 1: Grid Splitter -->
                <ColumnDefinition Width="*" MinWidth="300"/>                                          <!-- Col 2: Center Editor TabView -->
                <ColumnDefinition Width="Auto"/>                                                      <!-- Col 3: Grid Splitter -->
                <ColumnDefinition x:Name="PreviewColumn" Width="400" MinWidth="150" MaxWidth="1500"/>  <!-- Col 4: Right Split Preview Panel -->
            </Grid.ColumnDefinitions>

            <controls:LeftSidebarPane x:Name="LeftSidebarTabView" Grid.Column="0" />

            <!-- B. Sidebar Splitter -->
            <local:CustomSplitter x:Name="LeftSplitter" Grid.Column="1" Width="2" HorizontalAlignment="Stretch" Background="{ThemeResource SplitterBackgroundBrush}"
                                  PointerPressed="OnLeftSplitterPointerPressed"
                                  PointerMoved="OnLeftSplitterPointerMoved"
                                  PointerReleased="OnLeftSplitterPointerReleased"/>

            <!-- C. Central Tabbed Document Editor -->
            <controls:EditorWorkspacePane x:Name="EditorWorkspace" Grid.Column="2"/>

            <!-- D. Preview Splitter -->
            <local:CustomSplitter x:Name="RightSplitter" Grid.Column="3" Width="2" HorizontalAlignment="Stretch" Background="{ThemeResource SplitterBackgroundBrush}"
                                  PointerPressed="OnRightSplitterPointerPressed"
                                  PointerMoved="OnRightSplitterPointerMoved"
                                  PointerReleased="OnRightSplitterPointerReleased"/>

            <!-- E. Right Tabbed Panel (Live Preview & AI Assistant) -->
            <controls:RightSidebarPane x:Name="PreviewGrid" Grid.Column="4" />
        </Grid>

        <controls:StatusBarPane x:Name="StatusBarPane" Grid.Row="4"/>

        <!-- 7. Drag & Drop Overlay to prevent WebView2 platform-level stuck icon bug -->
        <Grid x:Name="DragOverlay"
              Grid.Row="0" Grid.RowSpan="5"
              Background="Transparent"
              AllowDrop="True"
              DragOver="OnDragOverlayOver"
              Drop="OnDragOverlayDrop"
              DragLeave="OnDragOverlayLeave"
              Visibility="Collapsed"/>
    </Grid>
</Window>
