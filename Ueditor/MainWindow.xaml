<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Ueditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ueditor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Ueditor">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent" AllowDrop="True" DragOver="OnRootDragOver" Drop="OnRootDrop" KeyDown="OnRootKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="36"/> <!-- Custom Title Bar -->
            <RowDefinition Height="Auto"/> <!-- Top Command Toolbar -->
            <RowDefinition Height="Auto"/> <!-- Markdown Toolbar -->
            <RowDefinition Height="*"/>    <!-- Main Body Work Area -->
            <RowDefinition Height="Auto"/> <!-- Bottom Status Bar -->
        </Grid.RowDefinitions>

        <!-- 0. Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Ueditor" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="16,0,0,0"
                       Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
        </Grid>

        <!-- 1. Top Command Toolbar (상단 툴바) -->
        <CommandBar Grid.Row="1" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" DefaultLabelPosition="Right">
            <AppBarButton Icon="OpenFile" Label="파일 열기" Click="OnOpenFileClick" AccessKey="O" ToolTipService.ToolTip="파일 열기 (Ctrl+O)"/>
            <AppBarButton Icon="Save" Label="저장" Click="OnSaveFileClick" AccessKey="S" ToolTipService.ToolTip="저장 (Ctrl+S)"/>
            <AppBarButton Label="비교" Click="OnCompareFilesClick" ToolTipService.ToolTip="파일 비교 (Diff)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8D4;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarToggleButton x:Name="TerminalToggleButton" Click="OnOpenTerminalClick" ToolTipService.ToolTip="터미널 (Ctrl+T)">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE756;"/>
                </AppBarToggleButton.Icon>
                <AppBarToggleButton.Label>터미널</AppBarToggleButton.Label>
            </AppBarToggleButton>
            <AppBarToggleButton x:Name="TopMostToggleButton" Click="OnTopMostToggleClick" ToolTipService.ToolTip="항상 위">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE840;"/>
                </AppBarToggleButton.Icon>
                <AppBarToggleButton.Label>항상위</AppBarToggleButton.Label>
            </AppBarToggleButton>
            <AppBarButton Label="스티커" Click="OnStickyNoteClick" ToolTipService.ToolTip="스티커 노트">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE70B;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarToggleButton x:Name="WordWrapToggle" Icon="AlignLeft" Label="Word Wrap" Click="OnWordWrapToggleClick" IsChecked="True"/>
            <AppBarButton Icon="Find" Label="검색" Click="OnFindClick" ToolTipService.ToolTip="검색 (Ctrl+F)"/>
            <AppBarSeparator/>
            <AppBarToggleButton x:Name="MarkdownToolbarToggle" Click="OnToggleMarkdownToolbarClick" ToolTipService.ToolTip="마크다운 툴바 토글">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE70F;"/>
                </AppBarToggleButton.Icon>
                <AppBarToggleButton.Label>Markdown</AppBarToggleButton.Label>
            </AppBarToggleButton>
            <AppBarSeparator/>
            <AppBarButton Label="테마" Click="OnToggleThemeClick">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE790;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Icon="Setting" Label="설정" Click="OnSettingsClick"/>
        </CommandBar>

        <CommandBar x:Name="MarkdownToolbar"
                    Grid.Row="2"
                    Height="34"
                    Visibility="Collapsed"
                    OverflowButtonVisibility="Auto"
                    DefaultLabelPosition="Collapsed"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <CommandBar.Resources>
                <Style TargetType="AppBarButton">
                    <Setter Property="MinWidth" Value="34"/>
                    <Setter Property="Width" Value="34"/>
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </CommandBar.Resources>
            <AppBarButton Label="Hx" Click="OnMarkdownHeadingClick" ToolTipService.ToolTip="제목">
                <AppBarButton.Icon>
                    <FontIcon Glyph="H" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Click="OnMarkdownBoldClick" ToolTipService.ToolTip="굵게 (Ctrl+B)" Label="">
                <TextBlock Text="B" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </AppBarButton>
            <AppBarButton Click="OnMarkdownItalicClick" ToolTipService.ToolTip="기울임 (Ctrl+I)" Label="">
                <TextBlock Text="I" FontSize="16" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </AppBarButton>
            <AppBarButton Click="OnMarkdownUnderlineClick" ToolTipService.ToolTip="밑줄 (Ctrl+U)" Label="">
                <Grid Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="U" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Border Height="1.5" Background="{ThemeResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Bottom" Margin="1,0,1,0"/>
                </Grid>
            </AppBarButton>
            <AppBarButton Click="OnMarkdownHighlightClick" ToolTipService.ToolTip="형광펜" Label="">
                <Border Background="#FFEB3B" CornerRadius="2" Padding="2,0,2,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="HL" FontSize="12" FontWeight="Bold" Foreground="Black"/>
                </Border>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="•" Click="OnMarkdownUlClick" ToolTipService.ToolTip="글머리 목록">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8FD;" FontSize="15"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="✂" Click="OnMarkdownCutLineClick" ToolTipService.ToolTip="현재 줄 자르기">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8C6;" FontSize="15"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="❝" Click="OnMarkdownQuoteClick" ToolTipService.ToolTip="인용문">
                <AppBarButton.Icon><FontIcon Glyph="&#xE90A;" FontSize="15"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="→" Click="OnMarkdownArrowClick" ToolTipService.ToolTip="화살표">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72A;" FontSize="15"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="`" Click="OnMarkdownInlineCodeClick" ToolTipService.ToolTip="인라인 코드">
                <AppBarButton.Icon><FontIcon Glyph="&#xE943;" FontSize="15"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="☑" Click="OnMarkdownTaskClick" ToolTipService.ToolTip="체크리스트">
                <AppBarButton.Icon><FontIcon Glyph="&#xE73A;" FontSize="15"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="표" Click="OnMarkdownTableClick" ToolTipService.ToolTip="표">
                <AppBarButton.Icon><FontIcon Glyph="&#xE80A;" FontSize="15"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="A+" Click="OnMarkdownFontIncreaseClick" ToolTipService.ToolTip="글자 크게"/>
            <AppBarButton Label="A-" Click="OnMarkdownFontDecreaseClick" ToolTipService.ToolTip="글자 작게"/>
            <AppBarButton x:Name="TextColorButton" Label="색" Click="OnMarkdownTextColorClick" ToolTipService.ToolTip="글자색 (우클릭: 색상 선택)" RightTapped="OnTextColorButtonRightTapped">
                <AppBarButton.ContextFlyout>
                    <Flyout x:Name="ColorPickerFlyout" Placement="Bottom">
                        <StackPanel Spacing="8" Padding="4">
                            <TextBlock Text="글자색 선택" FontWeight="SemiBold" FontSize="13"/>
                            <ColorPicker x:Name="TextColorPicker" IsAlphaEnabled="False" HorizontalAlignment="Stretch"/>
                            <Button Content="적용" Click="OnApplyTextColorClick" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Flyout>
                </AppBarButton.ContextFlyout>
            </AppBarButton>
            <AppBarButton Label="링크" Click="OnMarkdownLinkClick" ToolTipService.ToolTip="링크"/>
        </CommandBar>

        <!-- 2. Main Work Area -->
        <Grid x:Name="MainWorkGrid" Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ExplorerColumn" Width="260" MinWidth="150" MaxWidth="500"/> <!-- Col 0: Left Side Explorer Panel -->
                <ColumnDefinition Width="Auto"/>                                                      <!-- Col 1: Grid Splitter -->
                <ColumnDefinition Width="*" MinWidth="300"/>                                          <!-- Col 2: Center Editor TabView -->
                <ColumnDefinition Width="Auto"/>                                                      <!-- Col 3: Grid Splitter -->
                <ColumnDefinition x:Name="PreviewColumn" Width="400" MinWidth="150" MaxWidth="800"/>  <!-- Col 4: Right Split Preview Panel -->
            </Grid.ColumnDefinitions>

            <!-- A. Left Panel (File Explorer & Favorites & Snippets) -->
            <Grid x:Name="LeftSidebarTabView" Grid.Column="0" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                    <StackPanel Padding="0,6,0,6" Spacing="2">
                        <ToggleButton x:Name="ExplorerActivityButton" Tag="0" IsChecked="True" Click="OnLeftActivityClick" Width="48" Height="44" Padding="0" ToolTipService.ToolTip="탐색기">
                            <FontIcon Glyph="&#xE8B7;" FontSize="20"/>
                        </ToggleButton>
                        <ToggleButton x:Name="FavoritesActivityButton" Tag="1" Click="OnLeftActivityClick" Width="48" Height="44" Padding="0" ToolTipService.ToolTip="즐겨찾기">
                            <FontIcon Glyph="&#xE734;" FontSize="20"/>
                        </ToggleButton>
                        <ToggleButton x:Name="SnippetsActivityButton" Tag="2" Click="OnLeftActivityClick" Width="48" Height="44" Padding="0" ToolTipService.ToolTip="스니펫">
                            <FontIcon Glyph="&#xE943;" FontSize="20"/>
                        </ToggleButton>
                        <ToggleButton x:Name="GitActivityButton" Tag="3" Click="OnLeftActivityClick" Width="48" Height="44" Padding="0" ToolTipService.ToolTip="Git">
                            <FontIcon Glyph="&#xE8F7;" FontSize="20"/>
                        </ToggleButton>
                        <ToggleButton x:Name="SearchActivityButton" Tag="4" Click="OnLeftActivityClick" Width="48" Height="44" Padding="0" ToolTipService.ToolTip="검색">
                            <FontIcon Glyph="&#xE721;" FontSize="20"/>
                        </ToggleButton>
                        <ToggleButton x:Name="RecentActivityButton" Tag="5" Click="OnLeftActivityClick" Width="48" Height="44" Padding="0" ToolTipService.ToolTip="최근 파일">
                            <FontIcon Glyph="&#xE81C;" FontSize="20"/>
                        </ToggleButton>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1">
                    
                    <!-- Tab 1: File Explorer -->
                    <Grid x:Name="ExplorerSidebarPage">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="10" Spacing="8">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="↑" Click="OnExplorerUpClick" ToolTipService.ToolTip="상위 폴더" Padding="10,4,10,4"/>
                                    <Button Grid.Column="1" Content="폴더 선택..." HorizontalAlignment="Stretch" Click="OnSelectFolderClick" Style="{StaticResource AccentButtonStyle}"/>
                                    <Button Grid.Column="2" Click="OnOpenTerminalClick" ToolTipService.ToolTip="현재 폴더에서 터미널 열기" Padding="10,4,10,4">
                                        <FontIcon Glyph="&#xE756;" FontSize="14"/>
                                    </Button>
                                </Grid>
                                <TextBlock x:Name="ExplorerStatusText" Text="폴더를 선택하세요." FontSize="11" TextWrapping="Wrap" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                            <ListView x:Name="FileListView" Grid.Row="1" Margin="5" SelectionMode="Single" DoubleTapped="OnFileListViewDoubleTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="4,5,4,5" RightTapped="OnFileListViewItemRightTapped">
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="즐겨찾기에 추가" Click="OnAddFileToFavoritesClick" Tag="{Binding}"/>
                                    <MenuFlyoutItem Text="폴더를 즐겨찾기에 추가" Click="OnAddFolderToFavoritesClick" Tag="{Binding}"/>
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="16" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                    </Grid>

                    <!-- Tab 2: Favorites -->
                    <Grid x:Name="FavoritesSidebarPage" Padding="10" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="즐겨찾기 목록 (더블클릭하여 열기)" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,10"/>
                            <ListView x:Name="FavoritesListView" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnFavoriteItemDoubleTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5,0,5" ToolTipService.ToolTip="{Binding Path}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center">
                                                <FontIcon.Foreground>
                                                    <SolidColorBrush Color="{Binding IconColor}"/>
                                                </FontIcon.Foreground>
                                            </FontIcon>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Path}" FontSize="10" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnRemoveFavoriteClick" Tag="{Binding Path}" Padding="5" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                    </Grid>

                    <!-- Tab 3: Snippets Hub -->
                    <Grid x:Name="SnippetsSidebarPage" Padding="10" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="코드 및 수식 템플릿 (더블클릭하여 삽입)" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,10"/>
                            <ListView x:Name="SnippetsListView" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnSnippetItemDoubleTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnDeleteSnippetClick" Tag="{Binding Title}" Padding="5" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Button Grid.Row="2" Content="스니펫 추가..." HorizontalAlignment="Stretch" Click="OnAddSnippetClick" Margin="0,10,0,0" Style="{StaticResource AccentButtonStyle}"/>
                    </Grid>

                    <!-- Tab 4: Git Panel -->
                    <Grid x:Name="GitSidebarPage" Padding="10" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Branch Info -->
                                <RowDefinition Height="*"/>    <!-- Changed Files -->
                                <RowDefinition Height="Auto"/> <!-- Commit controls -->
                                <RowDefinition Height="Auto"/> <!-- Bottom Actions -->
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,10" Spacing="5">
                                <TextBlock Text="Git 저장소 관리" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock x:Name="GitPanelBranchText" Text="Git: 감지 안됨" FontSize="13" FontWeight="SemiBold"/>
                                <ComboBox x:Name="GitBranchesCombo" PlaceholderText="브랜치 목록" Height="28" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <ListView x:Name="GitChangedFilesList" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnGitFileDoubleTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Path}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="3" Padding="4,1,4,1" Margin="5,0,5,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <Button Grid.Column="2" Content="{Binding ActionGlyph}" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnGitStageToggleClick" Tag="{Binding Path}" Padding="5" VerticalAlignment="Center"/>
                                            <Button Grid.Column="3" Content="&#xE777;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnGitRestoreFileClick" Tag="{Binding Path}" Padding="5" VerticalAlignment="Center" ToolTipService.ToolTip="파일 복원"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <StackPanel Grid.Row="2" Spacing="8" Margin="0,10,0,0">
                                <TextBox x:Name="GitCommitMessageInput" PlaceholderText="커밋 메시지 입력..." Height="60" AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                <Button Content="커밋 (Commit)" HorizontalAlignment="Stretch" Click="OnGitCommitClick" Style="{StaticResource AccentButtonStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Spacing="8" Margin="0,8,0,0">
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="전체 Stage" HorizontalAlignment="Stretch" Click="OnGitStageAllClick"/>
                                    <Button Grid.Column="1" Content="전체 Restore" HorizontalAlignment="Stretch" Click="OnGitRestoreAllClick"/>
                                </Grid>
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Push" HorizontalAlignment="Stretch" Click="OnGitPushClick"/>
                                    <Button Grid.Column="1" Content="새로고침" HorizontalAlignment="Stretch" Click="OnGitRefreshClick"/>
                                </Grid>
                                <TextBlock Text="과거 기록" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <ListView x:Name="GitHistoryList" Height="92" SelectionMode="None"/>
                            </StackPanel>
                    </Grid>

                    <!-- Tab 5: Search & Replace Panel -->
                    <Grid x:Name="SearchSidebarPage" Padding="10" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Form Inputs -->
                                <RowDefinition Height="*"/>    <!-- Results -->
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,10">
                                <TextBlock Text="폴더 전체 검색 및 치환" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="SearchQueryInput" PlaceholderText="검색어 입력..." KeyDown="OnSearchQueryInputKeyDown"/>
                                <TextBox x:Name="ReplaceQueryInput" PlaceholderText="치환할 단어 입력..."/>
                                
                                <Grid ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="SearchMatchCaseToggle" Content="Aa" ToolTipService.ToolTip="대소문자 구분" HorizontalAlignment="Stretch"/>
                                    <ToggleButton x:Name="SearchWholeWordToggle" Content="[ab]" Grid.Column="1" ToolTipService.ToolTip="단어 단위" HorizontalAlignment="Stretch"/>
                                    <ToggleButton x:Name="SearchRegexToggle" Content=".*" Grid.Column="2" ToolTipService.ToolTip="정규식 검색" HorizontalAlignment="Stretch"/>
                                </Grid>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="전체 검색" HorizontalAlignment="Stretch" Click="OnSearchAllFilesClick" Style="{StaticResource AccentButtonStyle}"/>
                                    <Button Content="모두 치환" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnReplaceAllClick"/>
                                </Grid>
                            </StackPanel>

                            <ListView x:Name="SearchResultsList" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnSearchResultDoubleTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding HeaderText}" FontWeight="Bold" FontSize="11" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                <TextBlock Text="{Binding LineContent}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DisplayPath}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                    </Grid>

                    <!-- Tab 6: Recent Files -->
                    <Grid x:Name="RecentSidebarPage" Padding="10" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="최근 열린 파일 (더블클릭하여 열기)" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,10"/>
                        <ListView x:Name="RecentFilesListView" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnRecentFileItemDoubleTapped">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,5,0,5" ToolTipService.ToolTip="{Binding Path}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Path}" FontSize="10" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnRemoveRecentFileClick" Tag="{Binding Path}" Padding="5" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Grid>

            <!-- B. Sidebar Splitter -->
            <local:CustomSplitter x:Name="LeftSplitter" Grid.Column="1" Width="2" HorizontalAlignment="Stretch" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                  PointerPressed="OnLeftSplitterPointerPressed"
                                  PointerMoved="OnLeftSplitterPointerMoved"
                                  PointerReleased="OnLeftSplitterPointerReleased"/>

            <!-- C. Central Tabbed Document Editor -->
            <Grid Grid.Column="2" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="TerminalPanelRow" Height="0"/>
                </Grid.RowDefinitions>
                <TabView x:Name="EditorTabView"
                         Grid.Row="0"
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         AddTabButtonClick="OnEditorTabViewAddTabClick"
                         TabCloseRequested="OnEditorTabViewTabCloseRequested"
                         SelectionChanged="OnEditorTabViewSelectionChanged">
                    <TabView.TabItems>
                        <!-- Dynamic tabs go here -->
                    </TabView.TabItems>
                </TabView>
                <Grid x:Name="TerminalPanel" Grid.Row="1" Visibility="Collapsed" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Padding="8,5,8,5" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TerminalTitleText" Text="터미널" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                        <Button Grid.Column="1" Content="닫기" Click="OnCloseTerminalClick" Padding="10,3,10,3"/>
                    </Grid>
                    <Border x:Name="TerminalHostBorder" Grid.Row="1" Grid.RowSpan="2" Background="Black" Visibility="Collapsed" SizeChanged="OnTerminalHostBorderSizeChanged"/>
                    <TextBox x:Name="TerminalOutputTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="12"
                             BorderThickness="0"
                             Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                             Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                    <Grid x:Name="TerminalInputAreaGrid" Grid.Row="2" Padding="8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PS>" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBox x:Name="TerminalInputBox"
                                 Grid.Column="1"
                                 PlaceholderText="명령 입력 후 Enter"
                                 FontFamily="Consolas"
                                 Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                 KeyDown="OnTerminalInputKeyDown"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- D. Preview Splitter -->
            <local:CustomSplitter x:Name="RightSplitter" Grid.Column="3" Width="2" HorizontalAlignment="Stretch" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                  PointerPressed="OnRightSplitterPointerPressed"
                                  PointerMoved="OnRightSplitterPointerMoved"
                                  PointerReleased="OnRightSplitterPointerReleased"/>

            <!-- E. Right Tabbed Panel (Live Preview & AI Assistant) -->
            <Grid Grid.Column="4" x:Name="PreviewGrid" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <TabView x:Name="RightTabView" 
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         IsAddTabButtonVisible="False" AllowDropTabs="False">
                    
                    <!-- Tab 1: Live Preview -->
                    <TabViewItem Header="실시간 프리뷰" IsClosable="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Preview Toolbar -->
                            <CommandBar Grid.Row="0" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Height="40" DefaultLabelPosition="Right">
                                <CommandBar.Content>
                                    <StackPanel Orientation="Horizontal" Margin="10,8,0,0" Spacing="10">
                                        <ComboBox x:Name="PreviewModeCombo" SelectedIndex="0" Height="24" Padding="5,0,5,0" Width="120" FontSize="11" SelectionChanged="OnPreviewModeComboSelectionChanged">
                                            <ComboBoxItem Content="Markdown"/>
                                            <ComboBoxItem Content="HTML Source"/>
                                            <ComboBoxItem Content="LaTeX Block"/>
                                        </ComboBox>
                                        <Button Click="OnOpenPreviewInBrowserClick" Height="24" Padding="8,0,8,0" ToolTipService.ToolTip="HTML 미리보기를 브라우저로 열기">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE774;" FontSize="12"/>
                                                <TextBlock Text="브라우저" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </CommandBar.Content>
                            </CommandBar>

                            <WebView2 x:Name="PreviewWebView" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Grid>
                    </TabViewItem>

                    <!-- Tab 2: AI Assistant -->
                    <TabViewItem Header="AI Assistant" IsClosable="False">
                        <Grid Padding="15" RowSpacing="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- AI Settings Summary -->
                                <RowDefinition Height="*"/>    <!-- AI Chat Logs Area -->
                                <RowDefinition Height="Auto"/> <!-- Selection Context Visualizer -->
                                <RowDefinition Height="Auto"/> <!-- Quick Action Buttons -->
                            </Grid.RowDefinitions>

                            <!-- Row 0: AI Settings Summary -->
                            <StackPanel Grid.Row="0" Spacing="8">
                                <TextBlock Text="AI 서비스 설정" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Text="API Key와 모델은 상단 설정 > LLM에서 관리합니다." TextWrapping="Wrap" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>

                            <!-- Row 1: AI Chat Output Area -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" Padding="10" CornerRadius="4">
                                <TextBlock x:Name="LlmOutputText" Text="대기 중... 에디터에서 영역을 선택한 후 하단의 AI 분석 도구를 사용해 보세요." TextWrapping="Wrap" FontSize="13" LineHeight="1.5" IsTextSelectionEnabled="True"/>
                            </ScrollViewer>

                            <!-- Row 2: Selected Context Info visualizer -->
                            <Border Grid.Row="2" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Padding="8" CornerRadius="4">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE94A;" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="SelectionStatsText" Text="선택 영역: 없음 (전체 전송 차단 활성화)" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="LlmFileContextInput" PlaceholderText="파일 맥락 없음" IsReadOnly="True" Height="30" FontSize="11"/>
                                        <Button Grid.Column="1" Content="파일 맥락 추가" Click="OnLlmAddFileContextClick" Padding="10,4,10,4"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Row 3: Quick Action Buttons -->
                            <StackPanel Grid.Row="3" Spacing="8">
                                <Button Content="선택 영역 설명 (Explain)" HorizontalAlignment="Stretch" Click="OnLlmExplainClick" Style="{StaticResource AccentButtonStyle}"/>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="선택 영역 요약" Grid.Column="0" HorizontalAlignment="Stretch" Click="OnLlmSummarizeClick"/>
                                    <Button Content="선택 영역 번역" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnLlmTranslateClick"/>
                                </Grid>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="수식/마크다운 개선" HorizontalAlignment="Stretch" Click="OnLlmImproveClick"/>
                                </Grid>
                                
                                <Grid ColumnSpacing="8" Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LlmCustomPromptInput" Grid.Column="0" PlaceholderText="질문이나 커스텀 지시사항 입력..." Height="32"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Button Content="실행" Click="OnLlmCustomClick" Style="{StaticResource AccentButtonStyle}"/>
                                        <Button Content="입력" Click="OnLlmInsertOutputClick" ToolTipService.ToolTip="AI 응답을 현재 커서에 입력"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </TabViewItem>

                </TabView>
            </Grid>
        </Grid>

        <!-- 3. Bottom Status Bar (하단 상태바) -->
        <Border Grid.Row="4" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Height="30" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="6,0,6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ToggleButton x:Name="LeftPanelToggle" Grid.Column="0" Width="30" Height="24" Padding="0" IsChecked="True" Click="OnToggleLeftPanelClick" ToolTipService.ToolTip="좌측 패널">
                    <FontIcon Glyph="&#xE8A7;" FontSize="13"/>
                </ToggleButton>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="줄" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock x:Name="StatusLine" Text="1" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBlock Text="," FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Text="열" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock x:Name="StatusCol" Text="1" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusFileStats" Text="크기: 0 bytes" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusGitBranch" Text="Git: 감지 안됨" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="3" Padding="6,1,6,1">
                        <TextBlock x:Name="StatusMode" Text="일반 모드" FontSize="10" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock x:Name="StatusLanguage" Text="PLAINTEXT" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox x:Name="StatusEncodingCombo"
                              Width="104"
                              Height="24"
                              FontSize="11"
                              Padding="6,0,4,0"
                              SelectionChanged="OnStatusEncodingSelectionChanged"
                              ToolTipService.ToolTip="파일 인코딩 선택"/>
                </StackPanel>

                <ToggleButton x:Name="RightPanelToggle" Grid.Column="4" Width="30" Height="24" Padding="0" IsChecked="True" Click="OnTogglePreviewClick" ToolTipService.ToolTip="우측 패널" Margin="10,0,0,0">
                    <FontIcon Glyph="&#xE8A7;" FontSize="13" RenderTransformOrigin="0.5,0.5">
                        <FontIcon.RenderTransform>
                            <ScaleTransform ScaleX="-1"/>
                        </FontIcon.RenderTransform>
                    </FontIcon>
                </ToggleButton>
            </Grid>
        </Border>

        <!-- 7. Drag & Drop Overlay to prevent WebView2 platform-level stuck icon bug -->
        <Grid x:Name="DragOverlay"
              Grid.Row="0" Grid.RowSpan="5"
              Background="Transparent"
              AllowDrop="True"
              DragOver="OnDragOverlayOver"
              Drop="OnDragOverlayDrop"
              DragLeave="OnDragOverlayLeave"
              Visibility="Collapsed"/>
    </Grid>
</Window>

