<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Ueditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ueditor"
    xmlns:controls="using:Ueditor.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Ueditor">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent" AllowDrop="True" DragOver="OnRootDragOver" Drop="OnRootDrop" KeyDown="OnRootKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="36"/> <!-- Custom Title Bar -->
            <RowDefinition Height="Auto"/> <!-- Top Command Toolbar -->
            <RowDefinition Height="Auto"/> <!-- Markdown Toolbar -->
            <RowDefinition Height="*"/>    <!-- Main Body Work Area -->
            <RowDefinition Height="Auto"/> <!-- Bottom Status Bar -->
        </Grid.RowDefinitions>

        <!-- 0. Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Ueditor" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="16,0,0,0"
                       Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
        </Grid>

        <!-- 1. Top Command Toolbar (상단 툴바) -->
        <CommandBar x:Name="TopCommandBar" Grid.Row="1" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" DefaultLabelPosition="Right">
            <AppBarButton x:Name="OpenFileButton" Icon="OpenFile" Label="파일 열기" Click="OnOpenFileClick" AccessKey="O" ToolTipService.ToolTip="파일 열기 (Ctrl+O)"/>
            <AppBarButton x:Name="SaveFileButton" Icon="Save" Label="저장" Click="OnSaveFileClick" AccessKey="S" ToolTipService.ToolTip="저장 (Ctrl+S)"/>
            <AppBarButton x:Name="CompareButton" Label="비교" Click="OnCompareFilesClick" ToolTipService.ToolTip="파일 비교 (Diff)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8D4;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarToggleButton x:Name="TerminalToggleButton" Click="OnOpenTerminalClick" ToolTipService.ToolTip="터미널 (Ctrl+`)">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE756;"/>
                </AppBarToggleButton.Icon>
                <AppBarToggleButton.Label>터미널</AppBarToggleButton.Label>
            </AppBarToggleButton>
            <AppBarButton x:Name="PrintButton" Label="인쇄" Click="OnPrintClick" ToolTipService.ToolTip="인쇄 (Ctrl+P)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE749;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarToggleButton x:Name="TopMostToggleButton" Click="OnTopMostToggleClick" ToolTipService.ToolTip="항상 위">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE840;"/>
                </AppBarToggleButton.Icon>
                <AppBarToggleButton.Label>항상위</AppBarToggleButton.Label>
            </AppBarToggleButton>
            <AppBarButton x:Name="StickyNoteButton" Label="스티커" Click="OnStickyNoteClick" ToolTipService.ToolTip="스티커 노트">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE70B;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarToggleButton x:Name="WordWrapToggle" Icon="AlignLeft" Label="Word Wrap" Click="OnWordWrapToggleClick" IsChecked="True"/>
            <AppBarButton x:Name="SearchButton" Icon="Find" Label="검색" Click="OnFindClick" ToolTipService.ToolTip="검색 (Ctrl+F)"/>
            <AppBarSeparator/>
            <AppBarToggleButton x:Name="MarkdownToolbarToggle" Click="OnToggleMarkdownToolbarClick" ToolTipService.ToolTip="마크다운 툴바 토글">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE70F;"/>
                </AppBarToggleButton.Icon>
                <AppBarToggleButton.Label>Markdown</AppBarToggleButton.Label>
            </AppBarToggleButton>
            <AppBarSeparator/>
            <AppBarButton x:Name="ThemeButton" Label="테마" Click="OnToggleThemeClick">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE790;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton x:Name="SplitButton" Label="분할" ToolTipService.ToolTip="에디터 화면 분할">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE154;"/>
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="SplitNoneItem" Text="분할 없음 (단일)" Click="OnSplitNoneClick"/>
                        <MenuFlyoutItem x:Name="SplitVerticalItem" Text="좌우 분할" Click="OnSplitVerticalClick"/>
                        <MenuFlyoutItem x:Name="SplitHorizontalItem" Text="상하 분할" Click="OnSplitHorizontalClick"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton x:Name="SettingsButton" Icon="Setting" Label="설정" Click="OnSettingsClick"/>
        </CommandBar>

        <controls:MarkdownToolbarControl x:Name="MarkdownToolbar"
                                         Grid.Row="2"
                                         Visibility="Collapsed"/>

        <!-- 2. Main Work Area -->
        <Grid x:Name="MainWorkGrid" Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ExplorerColumn" Width="260" MinWidth="150" MaxWidth="500"/> <!-- Col 0: Left Side Explorer Panel -->
                <ColumnDefinition Width="Auto"/>                                                      <!-- Col 1: Grid Splitter -->
                <ColumnDefinition Width="*" MinWidth="300"/>                                          <!-- Col 2: Center Editor TabView -->
                <ColumnDefinition Width="Auto"/>                                                      <!-- Col 3: Grid Splitter -->
                <ColumnDefinition x:Name="PreviewColumn" Width="400" MinWidth="150" MaxWidth="800"/>  <!-- Col 4: Right Split Preview Panel -->
            </Grid.ColumnDefinitions>

            <controls:LeftSidebarPane x:Name="LeftSidebarTabView" Grid.Column="0" />

            <!-- B. Sidebar Splitter -->
            <local:CustomSplitter x:Name="LeftSplitter" Grid.Column="1" Width="2" HorizontalAlignment="Stretch" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                  PointerPressed="OnLeftSplitterPointerPressed"
                                  PointerMoved="OnLeftSplitterPointerMoved"
                                  PointerReleased="OnLeftSplitterPointerReleased"/>

            <!-- C. Central Tabbed Document Editor -->
            <Grid Grid.Column="2" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="TerminalSplitterRow" Height="0"/>
                    <RowDefinition x:Name="TerminalPanelRow" Height="0"/>
                </Grid.RowDefinitions>
                <Grid x:Name="EditorSplitGrid" Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="EditorRow1" Height="*"/>
                        <RowDefinition x:Name="EditorSplitterRow" Height="0"/>
                        <RowDefinition x:Name="EditorRow2" Height="0"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="EditorColumn1" Width="*"/>
                        <ColumnDefinition x:Name="EditorSplitterColumn" Width="0"/>
                        <ColumnDefinition x:Name="EditorColumn2" Width="0"/>
                    </Grid.ColumnDefinitions>

                    <TabView x:Name="EditorTabView"
                             Grid.Row="0" Grid.Column="0"
                             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                             AddTabButtonClick="OnEditorTabViewAddTabClick"
                             TabCloseRequested="OnEditorTabViewTabCloseRequested"
                             SelectionChanged="OnEditorTabViewSelectionChanged"
                             GotFocus="OnTabViewGotFocus">
                        <TabView.TabItems>
                            <!-- Dynamic tabs go here -->
                        </TabView.TabItems>
                    </TabView>

                    <local:CustomSplitter x:Name="EditorSplitter"
                                          Grid.Row="0" Grid.Column="1"
                                          Width="4"
                                          HorizontalAlignment="Stretch"
                                          Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                          Visibility="Collapsed"
                                          PointerPressed="OnEditorSplitterPointerPressed"
                                          PointerMoved="OnEditorSplitterPointerMoved"
                                          PointerReleased="OnEditorSplitterPointerReleased"/>

                    <TabView x:Name="EditorTabView2"
                             Grid.Row="0" Grid.Column="2"
                             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                             Visibility="Collapsed"
                             AddTabButtonClick="OnEditorTabView2AddTabClick"
                             TabCloseRequested="OnEditorTabView2TabCloseRequested"
                             SelectionChanged="OnEditorTabView2SelectionChanged"
                             GotFocus="OnTabViewGotFocus">
                        <TabView.TabItems>
                            <!-- Dynamic tabs go here -->
                        </TabView.TabItems>
                    </TabView>
                </Grid>
                <local:CustomSplitter x:Name="TerminalSplitter"
                                      Grid.Row="1"
                                      Height="4"
                                      HorizontalAlignment="Stretch"
                                      Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                      Visibility="Collapsed"
                                      PointerPressed="OnTerminalSplitterPointerPressed"
                                      PointerMoved="OnTerminalSplitterPointerMoved"
                                      PointerReleased="OnTerminalSplitterPointerReleased"/>
                <controls:TerminalPane x:Name="TerminalPane" Grid.Row="2" Visibility="Collapsed"/>
            </Grid>

            <!-- D. Preview Splitter -->
            <local:CustomSplitter x:Name="RightSplitter" Grid.Column="3" Width="2" HorizontalAlignment="Stretch" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                  PointerPressed="OnRightSplitterPointerPressed"
                                  PointerMoved="OnRightSplitterPointerMoved"
                                  PointerReleased="OnRightSplitterPointerReleased"/>

            <!-- E. Right Tabbed Panel (Live Preview & AI Assistant) -->
            <controls:RightSidebarPane x:Name="PreviewGrid" Grid.Column="4" />
        </Grid>

        <controls:StatusBarPane x:Name="StatusBarPane" Grid.Row="4"/>

        <!-- 7. Drag & Drop Overlay to prevent WebView2 platform-level stuck icon bug -->
        <Grid x:Name="DragOverlay"
              Grid.Row="0" Grid.RowSpan="5"
              Background="Transparent"
              AllowDrop="True"
              DragOver="OnDragOverlayOver"
              Drop="OnDragOverlayDrop"
              DragLeave="OnDragOverlayLeave"
              Visibility="Collapsed"/>
    </Grid>
</Window>

